# Copy this file to ".env.local" and fill in real values.
# Find these values in Firebase Console -> Project settings -> Your apps -> Web app config.

NEXT_PUBLIC_FB_API_KEY=
NEXT_PUBLIC_FB_AUTH_DOMAIN=
NEXT_PUBLIC_FB_PROJECT_ID=
NEXT_PUBLIC_FB_STORAGE_BUCKET=
NEXT_PUBLIC_FB_APP_ID=

# Gmail SMTP for outgoing booking emails.
# 1. Enable 2-Step Verification on the Gmail account.
# 2. Create an App Password at https://myaccount.google.com/apppasswords
# 3. Paste it below (spaces are fine — stripped before use).
GMAIL_USER=your-account@gmail.com
GMAIL_APP_PASSWORD=

# Used in email "View my booking" buttons. Defaults to http://localhost:3000.
# For production: set this to your live URL (e.g. https://your-app.vercel.app).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
