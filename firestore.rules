rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Properties: anyone can read, only admins write (manage from console for MVP).
    match /units/{unitId} {
      allow read: if true;
      allow write: if false;
    }

    // Bookings: anyone may create a pending booking with the required fields.
    // Only admins (custom claim) can read/update/delete.
    match /bookings/{bookingId} {
      allow create: if request.resource.data.status == 'pending'
                    && request.resource.data.keys().hasAll(
                         ['unitId','customer','checkIn','checkOut','totalAmount','status'])
                    && request.resource.data.totalAmount is number
                    && request.resource.data.totalAmount >= 0;
      allow read, update, delete: if request.auth != null
                                  && request.auth.token.admin == true;
    }

    // Settings: public read (payment QR/business info), admin write.
    match /settings/{doc} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
